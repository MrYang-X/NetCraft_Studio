---
/**
 * 加载界面组件
 * - 首次访问时显示启动画面
 * - 页面完全加载（含字体、图片）后自动淡出
 * - 配合 View Transitions 使用
 */

export interface Props {
  /** 加载提示文字 */
  text?: string;
}

const { text = 'Loading...' } = Astro.props;
---

<style>
  .loader-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    transition: opacity 0.5s ease, visibility 0.5s ease;
    /* 确保覆盖在页面内容之上 */
    will-change: opacity, visibility;
  }

  .loader-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Logo 动画 */
  .loader-logo {
    font-size: 2.8rem;
    font-weight: 700;
    color: rgb(var(--black));
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    user-select: none;
  }

  .loader-logo .accent {
    color: var(--accent);
  }

  .loader-logo .dot {
    display: inline-block;
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  /* 下划线动画 */
  .loader-underline {
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), transparent);
    border-radius: 2px;
    animation: expand 1.2s ease-out forwards;
    margin-bottom: 2rem;
  }

  @keyframes expand {
    to { width: 120px; }
  }

  /* 加载圆点 */
  .loader-dots {
    display: flex;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .loader-dot {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    animation: bounce 1.4s ease-in-out infinite both;
  }

  .loader-dot:nth-child(1) { animation-delay: -0.32s; }
  .loader-dot:nth-child(2) { animation-delay: -0.16s; }
  .loader-dot:nth-child(3) { animation-delay: 0s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1); }
  }

  .loader-text {
    color: rgb(var(--gray));
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  /* View Transition 导航时的加载指示器（顶部进度条） */
  .nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), #6c8cff, var(--accent));
    background-size: 200% 100%;
    z-index: 10000;
    width: 0;
    transition: none;
    pointer-events: none;
    animation: none;
  }

  .nav-bar.active {
    width: 60%;
    animation: progress 0.8s ease-in-out, shimmer 0.8s linear infinite;
  }

  @keyframes progress {
    from { width: 0; }
    to { width: 60%; }
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .nav-bar.complete {
    width: 100%;
    transition: width 0.3s ease;
    opacity: 0;
    transition: width 0.3s ease, opacity 0.4s ease 0.2s;
  }
</style>

<!-- 页面导航时的顶部进度条 -->
<div class="nav-bar" id="nav-bar"></div>

<!-- 首屏启动画面 -->
<div class="loader-overlay" id="app-loader">
  <div class="loader-logo">
    <span class="accent">N</span>et<span class="dot">•</span><span class="accent">C</span>raft
  </div>
  <div class="loader-underline"></div>
  <div class="loader-dots">
    <div class="loader-dot"></div>
    <div class="loader-dot"></div>
    <div class="loader-dot"></div>
  </div>
  <p class="loader-text">{text}</p>
</div>

<script>
  (function () {
    const loader = document.getElementById('app-loader');
    const navBar = document.getElementById('nav-bar');

    /** 隐藏启动画面 */
    function hideSplash() {
      if (!loader) return;
      // 添加 hidden 类触发淡出动画
      loader.classList.add('hidden');
      // 动画结束后从 DOM 移除
      setTimeout(() => {
        if (loader && loader.parentNode) {
          loader.parentNode.removeChild(loader);
        }
      }, 500);
    }

    // === 首次访问：等待页面完全加载后隐藏启动画面 ===
    if (document.readyState === 'complete') {
      // 给字体一个额外的渲染缓冲
      setTimeout(hideSplash, 200);
    } else {
      window.addEventListener('load', () => {
        // 等待字体渲染完成
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(hideSplash);
        } else {
          setTimeout(hideSplash, 300);
        }
      });
    }

    // === View Transitions 导航时显示顶部进度条 ===
    let navTimer: ReturnType<typeof setTimeout> | undefined;

    document.addEventListener('astro:before-preparation', () => {
      // 导航开始，显示进度条
      if (navBar) {
        navBar.classList.remove('complete');
        navBar.classList.add('active');
      }
      // 兜底：超过 5 秒自动完成
      clearTimeout(navTimer);
      navTimer = setTimeout(() => {
        if (navBar) {
          navBar.classList.remove('active');
          navBar.classList.add('complete');
        }
      }, 5000);
    });

    document.addEventListener('astro:after-swap', () => {
      // 导航完成，进度条走完并淡出
      clearTimeout(navTimer);
      if (navBar) {
        navBar.classList.remove('active');
        navBar.classList.add('complete');
        // 重置进度条
        setTimeout(() => {
          if (navBar) {
            navBar.classList.remove('complete');
            navBar.style.width = '';
          }
        }, 600);
      }
    });
  })();
</script>
